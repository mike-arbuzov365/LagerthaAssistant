{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=LagerthaAssistantDb;Username=postgres;Password=your_password"
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1/",
    "Model": "gpt-4.1-mini",
    "Temperature": 0.2
  },
  "AssistantSession": {
    "MaxHistoryMessages": 20
  },
  "VocabularyStorage": {
    "DefaultMode": "local"
  },
  "Graph": {
    "TenantId": "consumers",
    "ClientId": "458971c9-18fc-4513-bb93-8749b409225f",
    "Scopes": [
      "User.Read",
      "Files.ReadWrite",
      "offline_access"
    ],
    "RootPath": "/Apps/Flashcards Deluxe",
    "TokenCachePath": "%LOCALAPPDATA%\\LagerthaAssistant\\graph-token.json"
  },
  "VocabularyDecks": {
    "FolderPath": "%OneDrive%\\Apps\\Flashcards Deluxe",
    "FilePattern": "wm-*.xlsx",
    "ReadOnlyFileNames": [
      "wm-vocabulary-all-ru-en.xlsx",
      "wm-training-all-ru-en.xlsx",
      "wm-grammar-all-ru-en.xlsx"
    ],
    "NounDeckFileName": "wm-nouns-ua-en.xlsx",
    "VerbDeckFileName": "wm-verbs-us-en.xlsx",
    "IrregularVerbDeckFileName": "wm-irregular-verbs-ua-en.xlsx",
    "PhrasalVerbDeckFileName": "wm-phrasal-verbs-ua-en.xlsx",
    "AdjectiveDeckFileName": "wm-adjectives-ua-en.xlsx",
    "AdverbDeckFileName": "wm-adverbs-ua-en.xlsx",
    "PrepositionDeckFileName": "wm-prepositions-ua-en.xlsx",
    "ConjunctionDeckFileName": "wm-conjunctions-ua-en.xlsx",
    "PronounDeckFileName": "wm-pronouns-ua-en.xlsx",
    "PersistentExpressionDeckFileName": "wm-persistant-expressions-ua-en.xlsx",
    "FallbackDeckFileName": "wm-vocabulary-1-grade-ua-en.xlsx"
  },
  "VocabularySyncWorker": {
    "Enabled": false,
    "IntervalSeconds": 60,
    "BatchSize": 25,
    "RunOnStartup": true,
    "MaxBackoffSeconds": 300,
    "BackoffFactor": 2
  },
  "Notion": {
    "Enabled": false,
    "ApiKey": "",
    "DatabaseId": "",
    "ApiBaseUrl": "https://api.notion.com/v1",
    "Version": "2022-06-28",
    "ConflictMode": "update",
    "RequestTimeoutSeconds": 60,
    "KeyPropertyName": "Key",
    "WordPropertyName": "Word",
    "MeaningPropertyName": "Meaning",
    "ExamplesPropertyName": "Examples",
    "PartOfSpeechPropertyName": "PartOfSpeech",
    "DeckPropertyName": "DeckFile",
    "StorageModePropertyName": "StorageMode",
    "RowNumberPropertyName": "RowNumber",
    "LastSeenPropertyName": "LastSeenAtUtc"
  },
  "NotionSyncWorker": {
    "Enabled": false,
    "IntervalSeconds": 60,
    "BatchSize": 25,
    "RunOnStartup": true,
    "MaxBackoffSeconds": 300,
    "BackoffFactor": 2
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}



